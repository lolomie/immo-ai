# ═══════════════════════════════════════════════════════════════
#  Immo AI — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "groq" (free) or "anthropic" (paid, higher quality)
LLM_PROVIDER=groq

# ── Groq (free tier — console.groq.com) ──────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Anthropic (claude.ai/api) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001
# Model used specifically for validation (always Claude regardless of LLM_PROVIDER)
CLAUDE_VALIDATION_MODEL=claude-haiku-4-5-20251001

# ── Flask Server ──────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
PORT=5000

# ── Google Service Account ────────────────────────────────────────────────────
# Option A: Path to service account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=config/google-service-account.json
# Option B: Inline JSON (useful for deployment platforms like Railway/Render)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The ID from your spreadsheet URL:
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# ── Google Drive ──────────────────────────────────────────────────────────────
# The folder ID where generated .docx files will be stored.
# Right-click folder in Drive → Share → copy ID from URL.
# Leave empty to upload to the service account's root Drive.
DRIVE_FOLDER_ID=your_drive_folder_id_here

# ── Google Calendar ───────────────────────────────────────────────────────────
# Calendar ID for appointment sync. Use "primary" or a specific calendar email.
GCAL_CALENDAR_ID=primary

# ── Cal.com (cal.com/settings/developer/api-keys) ────────────────────────────
CALCOM_API_KEY=cal_live_your_key_here
# Event Type ID from: cal.com/event-types → click your event → URL contains the ID
CALCOM_EVENT_TYPE_ID=123456
CALCOM_BASE_URL=https://api.cal.com/v2

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Gmail example: use an App Password (not your main password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Immo AI

# ── Automation ────────────────────────────────────────────────────────────────
# How often the daemon checks for new rows (seconds)
AUTOMATION_POLL_INTERVAL=60
# Maximum retry attempts for API calls
AUTOMATION_MAX_RETRIES=3
# Secret for the /api/automation/trigger webhook (optional but recommended)
AUTOMATION_WEBHOOK_SECRET=change-this-webhook-secret

# ── Admin Login ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=
